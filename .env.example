# Morphix environment variables (reference only — client uses config.js)
# Copy config.example.js → config.js for the static app.

# Supabase (required for auth)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe billing webhook (Cloudflare Worker /api/webhooks/stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx

# Google OAuth (Supabase Dashboard → Authentication → Providers)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Local Supabase CLI: run `supabase status` after `supabase start`
# SUPABASE_URL=http://127.0.0.1:54321
