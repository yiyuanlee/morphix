# Morphix environment variables (reference only — client uses config.js)
# Copy config.example.js → config.js for the static app.

# Supabase (required for auth)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (Supabase Dashboard → Authentication → Providers)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Local Supabase CLI: run `supabase status` after `supabase start`
# SUPABASE_URL=http://127.0.0.1:54321

# Stripe Configuration (MVP Billing)
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_MONTHLY=your-stripe-monthly-price-id
STRIPE_PRICE_ANNUAL=your-stripe-annual-price-id

